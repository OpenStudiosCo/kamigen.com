extends /src/templates/website.pug

block append title
  | Home | Kamigen | A Tropical Cyberpunk World

block append scripts
  script(src='./dist/jumbotron.js')

block append content
  .row
    .column#jumbotron
      img.ui.image.fluid(src='./art/screenshots/Kamigen Island shot.PNG')
  .row.ui.page.grid
    .column.ten.wide
      h3.ui.dividing.header.inverted News
      .ui.grid.three.column.wide.very.relaxed.stackable
        .row.main
          .column.sixteen.wide
            .ui.grid.stackable
              .ui.two.column.grid.stackable
                .row
                  .column
                    a(href='/blog/20260716-why-we-didnt-use-gen-ai.html' title='Reclaiming the lost Visayan culture')
                        h3 Creative Somersault: Why we didn't use generative AI in Kamigen
                    small
                        em 16 July 2026
                    p Kamigen went away for a long time with no explanation. We felt it was only right to let you know what happened behind the scenes.
                    p
                        a(href='/blog/20260716-why-we-didnt-use-gen-ai.html' title='Reclaiming the lost Visayan culture') Read our blog post
                  .column
                    a(href='/comics/issue_5.html')
                        h3 Pages 129-133 are (finally) out!
                    small
                        em 15 July 2026
                    p The crisis on Kamigen Island continues, old enemies talk for the first time.
                    p
                        a(href='comics/page_129.html') Read page 129
                        |  or&nbsp;
                        a(href='comics.html') see all comics
                .row
                  .column
                    a(href='/comics/issue_5.html')
                      h3 Pages 125-128 are out!
                    small
                      em 16 October 2021
                    p The crisis in Mambajao 2 continues as Nick races against the clock.
                    p
                      a(href='comics/page_125.html') Read page 125
                      |  or&nbsp;
                      a(href='comics.html') see all comics
                  .column
                    a(href='/blog/20210930-reclaiming-the-lost-visayan-culture.html' title='Reclaiming the lost Visayan culture')
                      h3 Reclaiming the lost Visayan culture
                    small
                      em 30 September 2021
                    p The mythology of Visayan culture featured a diverse pantheon of unique indigenous deities, some of whom are featured as characters in the Kamigen comics.
                    p
                        a(href='/blog/20210930-reclaiming-the-lost-visayan-culture.html' title='Reclaiming the lost Visayan culture') Read more
                .row
                  .column
                    a(href='/comics/issue_5.html')
                      h3 Pages 121-124 are out!
                    small
                      em 29 August 2021
                    p The time has come - four fully coloured pages have been produced and posted on the Issue 5 page.
                    p We are hoping to have the next set out within 2 weeks and by October 1st at the latest.
                    p Want to support Kamigen?
                    ul
                      li
                        a(href='https://www.facebook.com/kamigenofficial') Like our Facebook page
                        | ,
                      li
                        a(href='https://www.instagram.com/kamigen_comics/') Follow us on Instagram
                  .column
                    a(href='/wiki/blog/20210827-late-august-production-update.html' title='Late August Production Update')
                      h3 Late August Production Update
                    small
                      em 27 August 2021
                    p It's been a while since we've posted so here's a quick rundown of what's been going on behind the scenes!
                    p The Kamigen Comics and Game are in heavy production so apologies we've not had time to keep the website up to date.
                .row
                  .column
                    a(href='/comics/issue_4.html' title='Go to Issue 04')
                      h3 Issue 4 is complete!
                    small
                      em 17 February 2020
                    p It's finally here - the final 5 pages of Issue 4 and the Issue 5 cover have been added.
                    p
                      a(href='https://www.facebook.com/kamigenofficial') Like our Facebook page
                      | ,
                      a(href='https://www.instagram.com/kamigen_comics/') follow us on Instagram
                      | .
                  .column
                    a(href='/comics/issue_4.html' title='Go to Issue 04')
                      h3 Over 100 pages of Kamigen are out!
                    small
                      em 21 July 2020
                    p This is a pretty special extra large release at 5 pages which has pushed the series to 103 pages.
                    p What mysteries lie waiting in Shangri Lah waiting to be discovered? Find out in&nbsp;
                      a(href='/comics/issue_4.html') Issue 04.
    .column.six.wide
      h3.ui.dividing.header.inverted Latest Pages
      a(href='/comics/issue_5.html' style='min-height: 250px; display: block; position: relative;')
        img.ui.image.fluid(src='./art/comics/SD/Kamigen%20Page%20129.png' style='clip: rect(12px, 380px, 250px, 12px); opacity: 0.5; position: absolute; z-index: 2;')
      h3.ui.dividing.header.inverted About Kamigen
      p Kamigen is a tropical cyberpunk world with aircraft combat.
      p
        a(href='./comics.html') Read the comics
        |  or play the&nbsp;
        a(href='/game.html') game demo
        | .
